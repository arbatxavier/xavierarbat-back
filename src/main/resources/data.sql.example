('my-first-post', '2024-01-01',
 '{"es": "Mi primer post", "ca": "El meu primer post", "en": "My first post"}',
 '{"es": "Una breve descripción del post.", "ca": "Una breu descripció del post.", "en": "A short description of the post."}',
 '{"es": "Aquí va el contenido completo en **markdown**.", "ca": "Aquí va el contingut complet en **markdown**.", "en": "Here goes the full content in **markdown**."}')
ON CONFLICT (slug) DO NOTHING;
