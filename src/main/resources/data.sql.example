('ILLUSTRATION', '{"en": "Illustration", "es": "Ilustración", "ca": "Il·lustració"}'),
('INK', '{"en": "Ink", "es": "Tinta", "ca": "Tinta"}'),
('FAN_ART', '{"en": "Fan Art", "es": "Fan Art", "ca": "Fan Art"}'),
('ANIME', '{"en": "Anime", "es": "Anime", "ca": "Anime"}'),
('MANGA', '{"en": "Manga", "es": "Manga", "ca": "Manga"}'),
('PORTRAIT', '{"en": "Portrait", "es": "Retrato", "ca": "Retrat"}'),
('CINEMA', '{"en": "Cinema", "es": "Cine", "ca": "Cinema"}'),
('HORROR', '{"en": "Horror", "es": "Terror", "ca": "Terror"}'),
('CONCEPT', '{"en": "Concept", "es": "Concepto", "ca": "Concepte"}'),
('ANIMALS', '{"en": "Animals", "es": "Animales", "ca": "Animals"}'),
('TECHNIQUE', '{"en": "Technique", "es": "Técnica", "ca": "Tècnica"}'),
